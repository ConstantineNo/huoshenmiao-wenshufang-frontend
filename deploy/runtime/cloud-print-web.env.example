## Copy this file to deploy/runtime/cloud-print-web.env on the server before the first deploy.
## If FRONTEND_DEPLOY_DIR points to /var/www/..., the deploy user should have passwordless sudo.
FRONTEND_DEPLOY_DIR=/var/www/cloud-print-web/current
FRONTEND_DOMAIN=print.1to.top
FRONTEND_CLIENT_MAX_BODY_SIZE=100m
CERTBOT_EMAIL=admin@1to.top
NGINX_SITE_NAME=cloud-print-web.conf
NGINX_SITE_AVAILABLE_DIR=/etc/nginx/sites-available
NGINX_SITE_ENABLED_DIR=/etc/nginx/sites-enabled
VITE_API_BASE_URL=https://api.print.1to.top